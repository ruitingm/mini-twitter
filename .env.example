# Service
SERVICE_NAME=user-service
PORT=8081

# Database
POSTGRES_PRIMARY_URL=postgres://twitter:twitter@localhost:5432/twitter
POSTGRES_REPLICA_URLS=postgres://twitter:twitter@localhost:5433/twitter,postgres://twitter:twitter@localhost:5434/twitter

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# Feature Flags
FANOUT_STRATEGY=write
CONSISTENCY_MODE=eventual
FANOUT_WORKER_COUNT=10
FANOUT_CHAN_BUFFER=10000
AGGREGATOR_INTERVAL=30s

# Internal Service URLs (for gateway)
USER_SERVICE_URL=http://localhost:8081
TWEET_SERVICE_URL=http://localhost:8082
TIMELINE_SERVICE_URL=http://localhost:8083

# Rate Limiting
RATE_LIMIT_RPM=60
